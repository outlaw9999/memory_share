#!/bin/sh
# Kit Post-Commit Hook (v1.2.5)
# Emits LIFECYCLE:POST_COMMIT with captured git diff for memory learning.

export KIT_GIT_DIFF=$(git diff HEAD~1...HEAD 2>/dev/null || echo "")
export KIT_GIT_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")
export KIT_GIT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

kit-runtime runtime --hook post-commit --json >/dev/null 2>&1
exit 0
