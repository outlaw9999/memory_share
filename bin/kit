#!/usr/bin/env python3
import argparse
import json
import os
import sqlite3
import subprocess
import sys
from pathlib import Path

# Constants
ENGINE_VERSION = "v1.0.0 (Frozen)"
CLI_VERSION = "v1.0.1"
WORKSPACE_ROOT = Path(os.environ.get("ANTIGRAVITY_WORKSPACE_ROOT", os.getcwd()))
KIT_PY = Path(__file__).parent.parent / "kit.py"
QUERIES_DIR = WORKSPACE_ROOT / ".antigravity" / "queries"
DB_PATH = WORKSPACE_ROOT / ".antigravity" / "atlas" / "atlas.db"

